{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zoom-meeting-bot.local/schemas/zoom-meeting-bot.config.schema.json",
  "title": "ZOOM_MEETING_BOT Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile",
    "zoom",
    "local_ai",
    "telegram",
    "runtime",
    "launcher"
  ],
  "properties": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bot_name",
        "workspace_name",
        "language",
        "timezone"
      ],
      "properties": {
        "bot_name": { "type": "string" },
        "workspace_name": { "type": "string" },
        "language": { "type": "string" },
        "timezone": { "type": "string" }
      }
    },
    "zoom": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "client_id",
        "client_secret",
        "meeting_sdk_enabled",
        "programmatic_join_enabled"
      ],
      "properties": {
        "client_id": { "type": "string" },
        "client_secret": { "type": "string" },
        "meeting_sdk_enabled": { "type": "boolean" },
        "programmatic_join_enabled": { "type": "boolean" }
      }
    },
    "local_ai": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "codex_command",
        "huggingface_token",
        "transcribe_model",
        "diarization_model",
        "meeting_output_device",
        "pandoc_command",
        "libreoffice_command",
        "whisper_cpp_command",
        "whisper_cpp_model"
      ],
      "properties": {
        "codex_command": { "type": "string" },
        "huggingface_token": { "type": "string" },
        "transcribe_model": { "type": "string" },
        "diarization_model": { "type": "string" },
        "meeting_output_device": { "type": "string" },
        "pandoc_command": { "type": "string" },
        "libreoffice_command": { "type": "string" },
        "whisper_cpp_command": { "type": "string" },
        "whisper_cpp_model": { "type": "string" }
      }
    },
    "telegram": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "bot_name",
        "bot_token",
        "conversation_route",
        "artifact_route"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "bot_name": { "type": "string" },
        "bot_token": { "type": "string" },
        "conversation_route": { "$ref": "#/$defs/route" },
        "artifact_route": { "$ref": "#/$defs/route" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_mode",
        "host",
        "port",
        "audio_mode",
        "store_path",
        "exports_dir",
        "audio_archive_dir",
        "state_path"
      ],
      "properties": {
        "execution_mode": {
          "type": "string",
          "enum": [
            "runtime_only",
            "launcher"
          ]
        },
        "host": { "type": "string" },
        "port": { "type": "integer" },
        "audio_mode": { "type": "string" },
        "store_path": { "type": "string" },
        "exports_dir": { "type": "string" },
        "audio_archive_dir": { "type": "string" },
        "state_path": { "type": "string" }
      }
    },
    "launcher": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "telegram_runner_backend",
        "metheus_route_name",
        "state_path"
      ],
      "properties": {
        "telegram_runner_backend": {
          "type": "string",
          "enum": [
            "none",
            "metheus_cli"
          ]
        },
        "metheus_route_name": { "type": "string" },
        "state_path": { "type": "string" }
      }
    }
  },
  "$defs": {
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "project_id",
        "destination_label",
        "chat_id"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "metheus_project",
            "personal_dm",
            "telegram_chat",
            "none"
          ]
        },
        "project_id": { "type": "string" },
        "destination_label": { "type": "string" },
        "chat_id": { "type": "string" }
      }
    }
  }
}
